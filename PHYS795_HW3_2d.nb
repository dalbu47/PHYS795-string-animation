  RowBox[{"(*", 
   RowBox[{
   "Parametric", " ", "plot", " ", "of", " ", "open", " ", "string", " ", 
    "worldsheet"}], "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"Assumptions", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"a", ",", "\[Alpha]"}], "}"}], "\[Element]", "Reals"}], "]"}], 
    ";"}], "\n", 
   RowBox[{
    RowBox[{"a", "=", "1"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"\[Alpha]", "=", "1"}], ";"}], "\n", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{
     "define", " ", "coordinates", " ", "as", " ", "functions", " ", "of", " ",
       "parameters", " ", "\[Tau]"}], ",", "\[Sigma]"}], "*)"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"X1", "[", 
      RowBox[{"\[Tau]_", ",", "\[Sigma]_"}], "]"}], " ", ":=", " ", 
     RowBox[{
      RowBox[{"-", 
       FractionBox["a", "2"]}], 
      SqrtBox["\[Alpha]"], " ", 
      RowBox[{"Cos", "[", 
       RowBox[{"2", "\[Sigma]"}], "]"}], 
      RowBox[{"Sin", "[", 
       RowBox[{"2", "\[Tau]"}], "]"}]}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"X2", "[", 
      RowBox[{"\[Tau]_", ",", "\[Sigma]_"}], "]"}], " ", ":=", " ", 
     RowBox[{"2", "a", 
      SqrtBox[
       RowBox[{"2", "\[Alpha]"}]], " ", 
      RowBox[{"Cos", "[", "\[Sigma]", "]"}], 
      RowBox[{"Sin", "[", "\[Tau]", "]"}]}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"X0", "[", 
      RowBox[{"\[Tau]_", ",", "\[Sigma]_"}], "]"}], " ", ":=", " ", 
     RowBox[{"2", "a", 
      SqrtBox["\[Alpha]"], 
      RowBox[{"(", 
       RowBox[{"\[Tau]", " ", "+", " ", 
        RowBox[{
         FractionBox["1", "4"], 
         RowBox[{"Cos", "[", 
          RowBox[{"2", "\[Sigma]"}], "]"}], 
         RowBox[{"Sin", "[", 
          RowBox[{"2", "\[Tau]"}], "]"}]}]}], ")"}]}]}], ";"}], "\n", "\n", 
   RowBox[{"ParametricPlot3D", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"X1", "[", 
